---
interface Props {
  shCategories: string[];
  toolCategories: string[];
  macCategories: string[];
  selectedCategories?: string[];
}

const { shCategories, toolCategories, macCategories } = Astro.props;

const sections = [
  {
    title: 'Self-hosted Apps',
    href: '/sh/',
    categories: shCategories,
    iconBg: 'bg-brand-blue-100 dark:bg-brand-blue-900',
    iconColor: 'text-brand-blue-600 dark:text-brand-blue-400',
    chip:
      'bg-brand-blue-50 text-brand-blue-800 hover:bg-brand-blue-100 dark:bg-brand-blue-900/40 dark:text-brand-blue-100 dark:hover:bg-brand-blue-900/70',
    path: 'M5 12h14M12 5l7 7-7 7',
  },
  {
    title: 'Online Tools',
    href: '/tools/',
    categories: toolCategories,
    iconBg: 'bg-brand-green-100 dark:bg-brand-green-900',
    iconColor: 'text-brand-green-600 dark:text-brand-green-400',
    chip:
      'bg-brand-green-50 text-brand-green-800 hover:bg-brand-green-100 dark:bg-brand-green-900/40 dark:text-brand-green-100 dark:hover:bg-brand-green-900/70',
    path: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  },
  {
    title: 'Mac Apps',
    href: '/mac/',
    categories: macCategories,
    iconBg: 'bg-brand-purple-100 dark:bg-brand-purple-900',
    iconColor: 'text-brand-purple-600 dark:text-brand-purple-400',
    chip:
      'bg-brand-purple-50 text-brand-purple-800 hover:bg-brand-purple-100 dark:bg-brand-purple-900/40 dark:text-brand-purple-100 dark:hover:bg-brand-purple-900/70',
    path: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
] as const;
---

<div class="bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700">
  <div class="grid grid-cols-1 md:grid-cols-3 md:divide-x divide-gray-100 dark:divide-gray-700">
    {
      sections.map((section) => (
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
              <span
                class={`flex h-8 w-8 items-center justify-center rounded-lg ${section.iconBg} mr-3`}
              >
                <svg
                  class={`w-5 h-5 ${section.iconColor}`}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={section.path}
                  />
                </svg>
              </span>
              {section.title}
            </h3>
            <a
              href={section.href}
              class="text-sm font-medium text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-white"
            >
              View all
            </a>
          </div>
          <div class="flex flex-wrap gap-2">
            {section.categories.slice(0, 8).map((category) => (
              <a
                href={`${section.href}?category=${encodeURIComponent(category)}`}
                class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue-500 ${section.chip}`}
              >
                {category}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>
