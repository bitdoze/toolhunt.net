---
interface Props {
  shCategories: string[];
  aiCategories?: string[];
  toolCategories: string[];
  macCategories: string[];
  selectedCategories?: string[];
}

const {
  shCategories,
  aiCategories = [],
  toolCategories,
  macCategories,
} = Astro.props;

const sections = [
  {
    title: 'Self-hosted',
    href: '/sh/',
    categories: shCategories,
    accent: 'bg-brand-blue-500',
    chip:
      'bg-slate-100 text-slate-700 hover:bg-brand-blue-50 hover:text-brand-blue-800 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-brand-blue-900/40 dark:hover:text-brand-blue-100',
  },
  {
    title: 'AI tools',
    href: '/ai/',
    categories: aiCategories,
    accent: 'bg-rose-500',
    chip:
      'bg-slate-100 text-slate-700 hover:bg-rose-50 hover:text-rose-800 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-rose-900/40 dark:hover:text-rose-100',
  },
  {
    title: 'Online tools',
    href: '/tools/',
    categories: toolCategories,
    accent: 'bg-brand-green-500',
    chip:
      'bg-slate-100 text-slate-700 hover:bg-brand-green-50 hover:text-brand-green-800 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-brand-green-900/40 dark:hover:text-brand-green-100',
  },
  {
    title: 'Mac apps',
    href: '/mac/',
    categories: macCategories,
    accent: 'bg-brand-purple-500',
    chip:
      'bg-slate-100 text-slate-700 hover:bg-brand-purple-50 hover:text-brand-purple-800 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-brand-purple-900/40 dark:hover:text-brand-purple-100',
  },
] as const;
---

<div class="th-card overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 md:divide-x md:divide-slate-200 dark:md:divide-slate-800">
    {
      sections.map((section) => (
        <div class="p-5 sm:p-6">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h3 class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">
              <span class:list={['h-2 w-2 rounded-full', section.accent]}></span>
              {section.title}
            </h3>
            <a
              href={section.href}
              class="text-sm font-medium text-slate-500 transition-colors hover:text-brand-blue-600 dark:text-slate-400 dark:hover:text-brand-blue-400"
            >
              View all
            </a>
          </div>
          <div class="flex flex-wrap gap-2">
            {(section.categories.length > 0 ? section.categories.slice(0, 8) : ['Browse all']).map(
              (category) => (
                <a
                  href={
                    section.categories.length > 0
                      ? `${section.href}?category=${encodeURIComponent(category)}`
                      : section.href
                  }
                  class:list={[
                    'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue-500',
                    section.chip,
                  ]}
                >
                  {category}
                </a>
              )
            )}
          </div>
        </div>
      ))
    }
  </div>
</div>
