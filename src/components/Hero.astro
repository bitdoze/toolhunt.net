---
import SearchBar from './SearchBar.astro';
import type { SearchIndexItem } from '../lib/content';

interface Props {
  totalTools: number;
  shCount: number;
  aiCount: number;
  toolsCount: number;
  macCount: number;
  alternativesCount: number;
  searchIndex: SearchIndexItem[];
}

const {
  totalTools,
  shCount,
  aiCount,
  toolsCount,
  macCount,
  alternativesCount,
  searchIndex,
} = Astro.props;

const collections = [
  {
    name: 'Self-hosted',
    count: shCount,
    href: '/sh/',
    badge: 'bg-brand-blue-50 text-brand-blue-700 dark:bg-brand-blue-950/60 dark:text-brand-blue-300 dark:border-brand-blue-800/40',
    iconBg: 'bg-brand-blue-500/10 text-brand-blue-600 dark:bg-brand-blue-400/10 dark:text-brand-blue-400',
  },
  {
    name: 'AI tools',
    count: aiCount,
    href: '/ai/',
    badge: 'bg-rose-50 text-rose-700 dark:bg-rose-950/60 dark:text-rose-300 dark:border-rose-800/40',
    iconBg: 'bg-rose-500/10 text-rose-600 dark:bg-rose-400/10 dark:text-rose-400',
  },
  {
    name: 'Online tools',
    count: toolsCount,
    href: '/tools/',
    badge: 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950/60 dark:text-emerald-300 dark:border-emerald-800/40',
    iconBg: 'bg-emerald-500/10 text-emerald-600 dark:bg-emerald-400/10 dark:text-emerald-400',
  },
  {
    name: 'Mac apps',
    count: macCount,
    href: '/mac/',
    badge: 'bg-brand-purple-50 text-brand-purple-700 dark:bg-brand-purple-950/60 dark:text-brand-purple-300 dark:border-brand-purple-800/40',
    iconBg: 'bg-brand-purple-500/10 text-brand-purple-600 dark:bg-brand-purple-400/10 dark:text-brand-purple-400',
  },
  {
    name: 'Alternatives',
    count: alternativesCount,
    href: '/alternatives/',
    badge: 'bg-brand-indigo-50 text-brand-indigo-700 dark:bg-brand-indigo-950/60 dark:text-brand-indigo-300 dark:border-brand-indigo-800/40',
    iconBg: 'bg-brand-indigo-500/10 text-brand-indigo-600 dark:bg-brand-indigo-400/10 dark:text-brand-indigo-400',
  },
] as const;
---

<section class="relative overflow-hidden border-b border-slate-200/80 dark:border-slate-800">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(37,99,235,0.08),transparent_60%)] dark:bg-[radial-gradient(ellipse_at_top,rgba(37,99,235,0.15),transparent_60%)]"></div>
  </div>

  <div class="th-container py-14 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3.5 py-1 text-xs font-medium text-slate-700 shadow-xs dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
        <span class="inline-block h-2 w-2 rounded-full bg-brand-blue-500 animate-pulse"></span>
        <span>{totalTools}+ curated software tools</span>
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl dark:text-white" style="text-wrap: balance;">
        Find the right tool
        <span class="block text-brand-blue-600 dark:text-brand-blue-400">for your workflow</span>
      </h1>

      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg dark:text-slate-300">
        Search self-hosted apps, online utilities, Mac applications, and privacy-first software alternatives with setup guides.
      </p>
    </div>

    <div class="mt-8 w-full text-left">
      <SearchBar
        tools={searchIndex}
        mode="global"
        placeholder="Search n8n, Photopea, Raycast alternatives..."
      />
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3.5 sm:grid-cols-3 lg:grid-cols-5" data-home-collections>
      {
        collections.map((item) => (
          <a
            href={item.href}
            class="th-card th-card-hover group relative flex flex-col justify-between p-4 transition-all"
          >
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
                  {item.name}
                </span>
                <span class:list={['inline-flex items-center justify-center rounded-lg px-2 py-0.5 text-xs font-bold border border-transparent', item.badge]}>
                  {item.count}
                </span>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between text-xs font-semibold text-brand-blue-600 dark:text-brand-blue-400">
              <span>Browse section</span>
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

