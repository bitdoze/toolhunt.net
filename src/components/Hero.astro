---
import SearchBar from './SearchBar.astro';
import type { SearchIndexItem } from '../lib/content';

interface Props {
  totalTools: number;
  shCount: number;
  toolsCount: number;
  macCount: number;
  alternativesCount: number;
  searchIndex: SearchIndexItem[];
}

const { totalTools, shCount, toolsCount, macCount, alternativesCount, searchIndex } = Astro.props;

const collections = [
  {
    name: 'Self-hosted',
    count: shCount,
    href: '/sh/',
    accent: 'bg-brand-blue-500',
    soft: 'bg-brand-blue-50 text-brand-blue-700 dark:bg-brand-blue-900/30 dark:text-brand-blue-100',
  },
  {
    name: 'Online tools',
    count: toolsCount,
    href: '/tools/',
    accent: 'bg-brand-green-500',
    soft: 'bg-brand-green-50 text-brand-green-700 dark:bg-brand-green-900/30 dark:text-brand-green-100',
  },
  {
    name: 'Mac apps',
    count: macCount,
    href: '/mac/',
    accent: 'bg-brand-purple-500',
    soft: 'bg-brand-purple-50 text-brand-purple-700 dark:bg-brand-purple-900/30 dark:text-brand-purple-100',
  },
  {
    name: 'Alternatives',
    count: alternativesCount,
    href: '/alternatives/',
    accent: 'bg-brand-indigo-500',
    soft: 'bg-brand-indigo-50 text-brand-indigo-700 dark:bg-brand-indigo-900/30 dark:text-brand-indigo-100',
  },
] as const;
---

<section class="relative overflow-hidden border-b border-slate-200/80 dark:border-slate-800">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(37,99,235,0.12),transparent_55%)] dark:bg-[radial-gradient(ellipse_at_top,rgba(37,99,235,0.18),transparent_55%)]"></div>
  </div>

  <div class="th-container py-14 sm:py-18 lg:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 inline-flex items-center rounded-full border border-slate-200 bg-white/80 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-600 shadow-sm dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-300">
        {totalTools}+ curated tools
      </p>

      <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl dark:text-white">
        Find the right tool
        <span class="block text-brand-blue-600 dark:text-brand-blue-400">for your workflow</span>
      </h1>

      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg dark:text-slate-300">
        Search self-hosted apps, online tools, Mac apps, and alternatives in one clean catalog.
      </p>

      <div class="mx-auto mt-8 max-w-xl text-left">
        <SearchBar
          tools={searchIndex}
          mode="global"
          placeholder="Search n8n, Photopea, Raycast alternatives..."
        />
      </div>

      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          collections.map((item) => (
            <a
              href={item.href}
              class="th-card th-card-hover group relative overflow-hidden p-4 text-left"
            >
              <span class:list={['absolute left-0 top-0 h-full w-1', item.accent]}></span>
              <p class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">
                {item.name}
              </p>
              <p class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
                {item.count}
              </p>
              <p class:list={['mt-2 inline-flex rounded-full px-2 py-0.5 text-xs font-medium', item.soft]}>
                Browse
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
