---
const { placeholder = "Search tools...", tools = [] } = Astro.props;
const searchQuery = Astro.url.searchParams.get('q') || '';
const hasClientSearch = tools.length > 0;

const fuseOptions = {
  keys: [
    'data.title',
    'data.description',
    'data.category',
    'data.alternativeTo',
    'data.keyFeatures',
    'body',
    'data.pricing',
    'data.tags',
    'data.requirements',
    'data.features',
    'slug'
  ],
  threshold: 0.3,
  includeScore: true,
  useExtendedSearch: true,
  ignoreLocation: true,
  fieldNormWeight: 1,
};
---

<div class="search-container">
  <form method="get" class="relative max-w-lg w-full" id="searchForm">
    <label for="search" class="sr-only">Search</label>
    <div class="relative">
      <div class="pointer-events-none absolute inset-y-0 left-0 pl-3 flex items-center">
        <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
        </svg>
      </div>
      <input
        type="search"
        name="q"
        id="search"
        value={searchQuery}
        class="block w-full bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg py-2 pl-10 pr-3 text-sm placeholder-gray-500 focus:outline-none focus:text-gray-900 dark:focus:text-white focus:placeholder-gray-400 focus:ring-1 focus:ring-brand-blue-500 focus:border-brand-blue-500 sm:text-sm"
        placeholder={placeholder}
        autocomplete="off"
      />
    </div>
  </form>

  {hasClientSearch && (
    <div id="search-results" class="mt-4 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"></div>
  )}
</div>

<script define:vars={{ tools, fuseOptions, hasClientSearch }}>
  async function initializeSearch() {
    const searchForm = document.getElementById('searchForm');
    const searchInput = document.getElementById('search');
    const searchResults = document.getElementById('search-results');

    if (!searchForm || !searchInput) return;
    if (searchForm.dataset.searchInitialized === 'true') return;
    searchForm.dataset.searchInitialized = 'true';

    // When there is no provided client dataset, keep native GET form behavior.
    if (!hasClientSearch || !searchResults) return;

    const { default: Fuse } = await import('fuse.js');
    const fuse = new Fuse(tools, fuseOptions);
    let searchTimeout;

    function updateUrl(query) {
      const currentUrl = new URL(window.location.href);
      const params = new URLSearchParams(currentUrl.search);
      if (query) {
        params.set('q', query);
      } else {
        params.delete('q');
      }
      const queryString = params.toString();
      window.history.replaceState({}, '', `${currentUrl.pathname}${queryString ? `?${queryString}` : ''}`);
    }

    function createBadge(text, className) {
      const badge = document.createElement('span');
      badge.className = className;
      badge.textContent = text;
      return badge;
    }

    function createResultCard(tool) {
      const card = document.createElement('a');
      card.href = `/${tool.collection}/${tool.slug}/`;
      card.className = 'block p-4 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition-shadow';

      const row = document.createElement('div');
      row.className = 'flex items-center space-x-4';

      const logo = document.createElement('img');
      logo.src = tool.data.logo;
      logo.alt = tool.data.title;
      logo.className = 'w-12 h-12 object-contain';

      const content = document.createElement('div');
      content.className = 'flex-1';

      const title = document.createElement('h3');
      title.className = 'text-lg font-medium text-gray-900 dark:text-white';
      title.textContent = tool.data.title;

      const description = document.createElement('p');
      description.className = 'text-sm text-gray-500 dark:text-gray-400';
      description.textContent = tool.data.description;

      const badges = document.createElement('div');
      badges.className = 'mt-2 flex flex-wrap gap-2';

      if (tool.data.category) {
        badges.appendChild(
          createBadge(
            tool.data.category,
            'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-blue-100 text-brand-blue-800 dark:bg-brand-blue-900 dark:text-brand-blue-200'
          )
        );
      }

      if (tool.data.alternativeTo) {
        badges.appendChild(
          createBadge(
            `Alternative to ${tool.data.alternativeTo}`,
            'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-green-100 text-brand-green-800 dark:bg-brand-green-900 dark:text-brand-green-200'
          )
        );
      }

      content.appendChild(title);
      content.appendChild(description);
      content.appendChild(badges);
      row.appendChild(logo);
      row.appendChild(content);
      card.appendChild(row);

      return card;
    }

    function displayResults(results) {
      const fragment = document.createDocumentFragment();
      for (const tool of results) {
        fragment.appendChild(createResultCard(tool));
      }
      searchResults.replaceChildren(fragment);
    }

    function performSearch() {
      const query = searchInput.value.trim();
      const results = query ? fuse.search(query).map((result) => result.item) : tools;
      displayResults(results);
      updateUrl(query);
    }

    searchForm.addEventListener('submit', (event) => {
      event.preventDefault();
      performSearch();
    });

    searchInput.addEventListener('search', () => {
      clearTimeout(searchTimeout);
      performSearch();
    });

    searchInput.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(performSearch, 300);
    });

    const initialQuery = new URLSearchParams(window.location.search).get('q');
    if (initialQuery) {
      searchInput.value = initialQuery;
      performSearch();
    } else {
      displayResults(tools);
    }
  }

  const globalScope = window;
  if (globalScope.__toolhuntSearchInit) {
    document.removeEventListener('astro:page-load', globalScope.__toolhuntSearchInit);
  }
  globalScope.__toolhuntSearchInit = initializeSearch;

  initializeSearch();
  document.addEventListener('astro:page-load', globalScope.__toolhuntSearchInit);
</script>

<style>
  .search-container {
    position: relative;
    width: 100%;
  }

  #search-results {
    width: 100%;
    z-index: 10;
  }
</style>
