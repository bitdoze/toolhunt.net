---
interface SearchTool {
  id: string;
  collection: string;
  title: string;
  description: string;
  category: string;
  logo: string;
  alternativeTo?: string;
  keyFeatures?: string[];
  pricing?: string;
}

interface Props {
  placeholder?: string;
  tools?: SearchTool[];
  mode?: 'global' | 'local';
}

const {
  placeholder = 'Search tools...',
  tools = [],
  mode = tools.length > 0 ? 'global' : 'local',
} = Astro.props;

const searchQuery = Astro.url.searchParams.get('q') || '';
const isGlobal = mode === 'global' && tools.length > 0;
const searchId = isGlobal ? 'global-search' : 'catalog-search';
const listboxId = `${searchId}-listbox`;
---

<div
  class={`search-container ${isGlobal ? 'search-global' : 'search-local'}`}
  data-search-mode={isGlobal ? 'global' : 'local'}
>
  {
    isGlobal && (
      <script type="application/json" data-search-index set:html={JSON.stringify(tools)} />
    )
  }

  <form method="get" class="relative w-full" data-search-form role="search">
    <label for={searchId} class="sr-only">Search</label>
    <div class="relative">
      <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
        <svg class="h-5 w-5 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
        </svg>
      </div>
      <input
        type="search"
        name="q"
        id={searchId}
        value={searchQuery}
        data-search-input
        class="block w-full rounded-xl border border-slate-300 bg-white py-2.5 pl-10 pr-10 text-sm text-slate-900 placeholder-slate-500 shadow-sm focus:border-brand-blue-500 focus:outline-none focus:ring-2 focus:ring-brand-blue-500 dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:placeholder-slate-400"
        placeholder={placeholder}
        autocomplete="off"
        enterkeyhint="search"
        role={isGlobal ? 'combobox' : undefined}
        aria-autocomplete={isGlobal ? 'list' : undefined}
        aria-controls={isGlobal ? listboxId : undefined}
        aria-expanded={isGlobal ? 'false' : undefined}
        aria-haspopup={isGlobal ? 'listbox' : undefined}
      />
      <button
        type="button"
        data-search-clear
        class={`absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-slate-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue-500 rounded dark:hover:text-slate-200 ${searchQuery ? '' : 'hidden'}`}
        aria-label="Clear search"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </form>

  {
    isGlobal && (
      <div class="mt-6 text-left" data-global-results hidden>
        <div class="mb-4 flex items-center justify-between gap-3">
          <p
            class="text-sm text-slate-500 dark:text-slate-400"
            data-global-count
            aria-live="polite"
            aria-atomic="true"
          />
          <button
            type="button"
            data-global-clear
            class="text-sm font-medium text-brand-blue-600 hover:text-brand-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue-500 rounded dark:text-brand-blue-400"
          >
            Clear search
          </button>
        </div>
        <div
          class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
          data-global-grid
          id={listboxId}
          role="listbox"
          aria-label="Search results"
        />
        <div class="hidden py-10 text-center" data-global-empty>
          <p class="text-lg font-semibold text-slate-900 dark:text-white">No matching tools</p>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            Try a shorter keyword, or clear search to browse the catalog again.
          </p>
          <button type="button" data-global-reset class="th-btn th-btn-primary mt-5">
            Clear search
          </button>
        </div>
        <p class="sr-only" data-search-hint>
          Use arrow keys to move, Enter to open, Escape to clear.
        </p>
      </div>
    )
  }
</div>

{isGlobal && <script src="../scripts/global-search.js"></script>}

{
  !isGlobal && (
    <script>
      function initLocalSearch(root: Element) {
        if (!(root instanceof HTMLElement) || root.dataset.bound === 'true') return;
        root.dataset.bound = 'true';

        const form = root.querySelector<HTMLFormElement>('[data-search-form]');
        const searchInput = root.querySelector<HTMLInputElement>('[data-search-input]');
        const clearBtn = root.querySelector<HTMLButtonElement>('[data-search-clear]');
        if (!form || !searchInput) return;

        const input = searchInput;
        let timer: ReturnType<typeof setTimeout> | undefined;

        function syncClear() {
          clearBtn?.classList.toggle('hidden', !input.value.trim());
        }

        function emitCatalogUpdate(resetPage = true) {
          document.dispatchEvent(
            new CustomEvent('toolhunt:catalog-update', {
              detail: {
                q: input.value.trim(),
                resetPage,
                source: 'search',
              },
            })
          );
        }

        form.addEventListener('submit', (event: Event) => {
          event.preventDefault();
          emitCatalogUpdate(true);
        });

        input.addEventListener('input', () => {
          syncClear();
          if (timer) clearTimeout(timer);
          timer = setTimeout(() => emitCatalogUpdate(true), 180);
        });

        input.addEventListener('search', () => {
          syncClear();
          emitCatalogUpdate(true);
        });

        input.addEventListener('keydown', (event: KeyboardEvent) => {
          if (event.key === 'Escape') {
            event.preventDefault();
            input.value = '';
            syncClear();
            emitCatalogUpdate(true);
          }
        });

        clearBtn?.addEventListener('click', () => {
          input.value = '';
          syncClear();
          emitCatalogUpdate(true);
          input.focus();
        });

        syncClear();
      }

      function bootLocal() {
        document.querySelectorAll('.search-local').forEach(initLocalSearch);
      }

      bootLocal();
      document.addEventListener('astro:page-load', bootLocal);
    </script>
  )
}
