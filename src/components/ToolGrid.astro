---
import ToolCard from './ToolCard.astro';
import type { ToolEntry } from '../lib/content';

interface Props {
  tools: ToolEntry[];
  showFullDetails?: boolean;
  /** First N logos load eagerly for better LCP on above-the-fold grids */
  eagerCount?: number;
}

const { tools, showFullDetails = false, eagerCount = 3 } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {
    tools.map((tool, index) => (
      <div class="h-full" data-tool-grid-item style={index >= 9 ? 'content-visibility: auto; contain-intrinsic-size: 280px;' : undefined}>
        <ToolCard entry={tool} showFullDetails={showFullDetails} priority={index < eagerCount} />
      </div>
    ))
  }
</div>
