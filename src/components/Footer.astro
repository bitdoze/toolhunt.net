---
import { Icon } from 'astro-icon/components';
import { getAllTools, sortByDateDesc, toolUrl } from '../lib/content';
import ToolImage from './ToolImage.astro';

const currentYear = new Date().getFullYear();
const latestTools = sortByDateDesc(await getAllTools()).slice(0, 5);
---

<footer class="mt-auto border-t border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-950">
  <div class="th-container py-12">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
          Catalog
        </h3>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="/sh/" class="text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
              Self-hosted apps
            </a>
          </li>
          <li>
            <a href="/ai/" class="text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
              AI tools
            </a>
          </li>
          <li>
            <a href="/tools/" class="text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
              Online tools
            </a>
          </li>
          <li>
            <a href="/mac/" class="text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
              Mac apps
            </a>
          </li>
          <li>
            <a href="/alternatives/" class="text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
              Alternatives
            </a>
          </li>
          <li>
            <a href="/blog/" class="text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
              Blog
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
          Latest tools
        </h3>
        <ul class="mt-4 space-y-3">
          {
            latestTools.map((tool) => (
              <li>
                <a href={toolUrl(tool)} class="flex items-center gap-3 group">
                  <ToolImage
                    src={tool.data.logo}
                    alt={tool.data.title}
                    width={32}
                    height={32}
                    class="h-8 w-8 rounded-lg border border-slate-200 bg-slate-50 object-contain p-0.5 dark:border-slate-700 dark:bg-slate-800"
                  />
                  <span class="truncate text-sm text-slate-600 transition-colors group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white">
                    {tool.data.title}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <div class="mb-3 flex items-center gap-2">
          <img src="/images/logo.svg" alt="ToolHunt Logo" class="h-8 w-8" width="32" height="32" />
          <span class="text-lg font-semibold tracking-tight text-slate-900 dark:text-white">ToolHunt</span>
        </div>
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
          Discover and compare self-hosted apps, online tools, Mac software, and alternatives.
        </p>
        <div class="mt-5 flex gap-4">
          <a href="https://twitter.com/bitdoze" class="text-slate-500 transition-colors hover:text-brand-blue-500 dark:text-slate-400" aria-label="Twitter">
            <Icon name="mdi:twitter" class="h-6 w-6" />
          </a>
          <a href="https://bsky.app/profile/bitdoze.com" class="text-slate-500 transition-colors hover:text-brand-blue-500 dark:text-slate-400" aria-label="Bluesky">
            <Icon name="mdi:web" class="h-6 w-6" />
          </a>
          <a href="https://www.youtube.com/channel/UCGsUtKhXsRrMvYAWm8q0bCg" class="text-slate-500 transition-colors hover:text-red-500 dark:text-slate-400" aria-label="YouTube">
            <Icon name="mdi:youtube" class="h-6 w-6" />
          </a>
          <a href="https://github.com/bitdoze" class="text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" aria-label="GitHub">
            <Icon name="mdi:github" class="h-6 w-6" />
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-slate-200 pt-6 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800">
      <p class="text-sm text-slate-500 dark:text-slate-400">
        © {currentYear} ToolHunt. All rights reserved.
      </p>
      <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
        <a href="/rss.xml" class="text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">RSS</a>
        <a href="/about/" class="text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">About</a>
        <a href="/contact/" class="text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">Contact</a>
        <a href="/privacy/" class="text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">Privacy</a>
        <a href="/submit/" class="text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">Submit</a>
      </div>
    </div>
  </div>
</footer>
