---
import Navigation from './Navigation.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-200/80 bg-white/85 backdrop-blur-md dark:border-slate-800 dark:bg-slate-950/80">
  <div class="th-container">
    <div class="flex h-16 items-center justify-between gap-4">
      <a href="/" class="group flex shrink-0 items-center gap-2.5">
        <img
          src="/images/logo.svg"
          alt="ToolHunt Logo"
          class="h-8 w-8 transition-transform duration-200 group-hover:scale-105"
          width="32"
          height="32"
        />
        <span class="text-lg font-semibold tracking-tight text-slate-900 transition-colors group-hover:text-brand-blue-600 dark:text-white dark:group-hover:text-brand-blue-400">
          ToolHunt
        </span>
      </a>

      <div class="flex min-w-0 flex-1 items-center justify-end gap-2 sm:gap-3">
        <Navigation />
        <div class="hidden h-6 w-px bg-slate-200 dark:bg-slate-700 sm:block"></div>
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>
