---
interface Props {
  categories: string[];
  alternativeTo?: string[];
  pricingOptions?: string[];
  showAlternativeTo?: boolean;
  showPricing?: boolean;
  categoryCounts?: Record<string, number>;
  alternativeCounts?: Record<string, number>;
  pricingCounts?: Record<string, number>;
}

const {
  categories,
  alternativeTo = [],
  pricingOptions = [],
  showAlternativeTo = false,
  showPricing = false,
  categoryCounts = {},
  alternativeCounts = {},
  pricingCounts = {},
} = Astro.props;
---

<form data-catalog-filters class="th-card space-y-5 p-4">
  <div class="flex items-center justify-between gap-2">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
      Filters
    </h2>
    <button type="button" data-clear-filters class="th-btn th-btn-ghost px-2 py-1 text-xs">
      Clear all
    </button>
  </div>

  <div data-active-filters class="hidden flex-wrap gap-2"></div>

  <div>
    <h3 class="mb-2.5 text-sm font-medium text-slate-800 dark:text-slate-200">Categories</h3>
    <div class="max-h-56 space-y-1 overflow-y-auto pr-1">
      {
        categories.map((category) => (
          <label class="flex cursor-pointer items-center justify-between gap-2 rounded-lg px-1.5 py-1.5 transition-colors hover:bg-slate-50 focus-within:ring-2 focus-within:ring-brand-blue-500 dark:hover:bg-slate-800/70">
            <span class="flex min-w-0 items-center">
              <input
                type="checkbox"
                name="category"
                value={category}
                class="h-4 w-4 rounded border-slate-300 text-brand-blue-600 focus:ring-brand-blue-500 dark:border-slate-600"
              />
              <span class="ml-2 truncate text-sm text-slate-600 dark:text-slate-300">{category}</span>
            </span>
            {categoryCounts[category] != null && (
              <span class="tabular-nums text-xs text-slate-400 dark:text-slate-500">
                {categoryCounts[category]}
              </span>
            )}
          </label>
        ))
      }
    </div>
  </div>

  {
    showPricing && pricingOptions.length > 0 && (
      <div>
        <h3 class="mb-2.5 text-sm font-medium text-slate-800 dark:text-slate-200">Pricing</h3>
        <div class="space-y-1">
          {pricingOptions.map((price) => (
            <label class="flex cursor-pointer items-center justify-between gap-2 rounded-lg px-1.5 py-1.5 transition-colors hover:bg-slate-50 focus-within:ring-2 focus-within:ring-brand-blue-500 dark:hover:bg-slate-800/70">
              <span class="flex min-w-0 items-center">
                <input
                  type="checkbox"
                  name="pricing"
                  value={price}
                  class="h-4 w-4 rounded border-slate-300 text-brand-blue-600 focus:ring-brand-blue-500 dark:border-slate-600"
                />
                <span class="ml-2 text-sm text-slate-600 dark:text-slate-300">{price}</span>
              </span>
              {pricingCounts[price] != null && (
                <span class="tabular-nums text-xs text-slate-400 dark:text-slate-500">
                  {pricingCounts[price]}
                </span>
              )}
            </label>
          ))}
        </div>
      </div>
    )
  }

  {
    showAlternativeTo && alternativeTo.length > 0 && (
      <div>
        <h3 class="mb-2.5 text-sm font-medium text-slate-800 dark:text-slate-200">Alternative to</h3>
        <div class="max-h-48 space-y-1 overflow-y-auto pr-1">
          {alternativeTo.map((alt) => (
            <label class="flex cursor-pointer items-center justify-between gap-2 rounded-lg px-1.5 py-1.5 transition-colors hover:bg-slate-50 focus-within:ring-2 focus-within:ring-brand-blue-500 dark:hover:bg-slate-800/70">
              <span class="flex min-w-0 items-center">
                <input
                  type="checkbox"
                  name="alternativeTo"
                  value={alt}
                  class="h-4 w-4 rounded border-slate-300 text-brand-blue-600 focus:ring-brand-blue-500 dark:border-slate-600"
                />
                <span class="ml-2 truncate text-sm text-slate-600 dark:text-slate-300">{alt}</span>
              </span>
              {alternativeCounts[alt] != null && (
                <span class="tabular-nums text-xs text-slate-400 dark:text-slate-500">
                  {alternativeCounts[alt]}
                </span>
              )}
            </label>
          ))}
        </div>
      </div>
    )
  }
</form>

<script>
  type FilterName = 'category' | 'pricing' | 'alternativeTo';

  function checkedValues(form: HTMLFormElement, name: FilterName): string[] {
    return Array.from(
      form.querySelectorAll<HTMLInputElement>(`input[name="${name}"]:checked`)
    ).map((input) => input.value);
  }

  function syncFromUrl(form: HTMLFormElement) {
    const params = new URLSearchParams(window.location.search);
    const selected: Record<FilterName, string[]> = {
      category: params.getAll('category'),
      alternativeTo: params.getAll('alternativeTo'),
      pricing: params.getAll('pricing'),
    };

    form.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((checkbox) => {
      const key = checkbox.name as FilterName;
      const list = selected[key] || [];
      checkbox.checked = list.includes(checkbox.value);
    });
  }

  function renderActiveChips(form: HTMLFormElement) {
    const host = form.querySelector<HTMLElement>('[data-active-filters]');
    if (!host) return;

    const chips: Array<{ name: FilterName; value: string }> = [];
    for (const name of ['category', 'pricing', 'alternativeTo'] as FilterName[]) {
      for (const value of checkedValues(form, name)) {
        chips.push({ name, value });
      }
    }

    if (chips.length === 0) {
      host.classList.add('hidden');
      host.replaceChildren();
      return;
    }

    host.classList.remove('hidden');
    host.classList.add('flex');
    host.replaceChildren(
      ...chips.map(({ name, value }) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className =
          'inline-flex items-center gap-1 rounded-full bg-brand-blue-50 px-2.5 py-1 text-xs font-medium text-brand-blue-800 dark:bg-brand-blue-900/50 dark:text-brand-blue-100';
        chip.dataset.removeName = name;
        chip.dataset.removeValue = value;
        chip.innerHTML = `${value}<span aria-hidden="true">×</span>`;
        chip.setAttribute('aria-label', `Remove ${value} filter`);
        return chip;
      })
    );
  }

  function emitUpdate(resetPage = true) {
    document.dispatchEvent(
      new CustomEvent('toolhunt:catalog-update', {
        detail: { resetPage, source: 'filters' },
      })
    );
  }

  function initFilters(form: Element) {
    if (!(form instanceof HTMLFormElement) || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    syncFromUrl(form);
    renderActiveChips(form);

    form.addEventListener('change', () => {
      renderActiveChips(form);
      emitUpdate(true);
    });

    form.querySelector('[data-clear-filters]')?.addEventListener('click', () => {
      form.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((checkbox) => {
        checkbox.checked = false;
      });
      renderActiveChips(form);
      emitUpdate(true);
    });

    form.querySelector('[data-active-filters]')?.addEventListener('click', (event: Event) => {
      const target = (event.target as HTMLElement | null)?.closest(
        'button[data-remove-name]'
      ) as HTMLButtonElement | null;
      if (!target) return;
      const name = target.dataset.removeName;
      const value = target.dataset.removeValue;
      if (!name || !value) return;
      const checkbox = form.querySelector<HTMLInputElement>(
        `input[type="checkbox"][name="${name}"][value="${CSS.escape(value)}"]`
      );
      if (checkbox) checkbox.checked = false;
      renderActiveChips(form);
      emitUpdate(true);
    });
  }

  function boot() {
    document.querySelectorAll('[data-catalog-filters]').forEach(initFilters);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
