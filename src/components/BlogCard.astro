---
import type { CollectionEntry } from 'astro:content';
import { blogUrl } from '../lib/content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const href = blogUrl(post);
const published = post.data.publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={href}
  class:list={[
    'th-card th-card-hover group flex h-full overflow-hidden',
    featured ? 'flex-col md:flex-row' : 'flex-col',
  ]}
>
  {
    post.data.image && (
      <div
        class:list={[
          'overflow-hidden bg-slate-100 dark:bg-slate-800',
          featured ? 'md:w-1/2' : 'w-full',
        ]}
      >
        <img
          src={post.data.image}
          alt={post.data.title}
          class:list={[
            'h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]',
            featured ? 'aspect-[16/10] md:aspect-auto md:min-h-full' : 'aspect-video',
          ]}
          width={featured ? 960 : 640}
          height={featured ? 600 : 360}
          loading={featured ? 'eager' : 'lazy'}
        />
      </div>
    )
  }

  <div class:list={['flex flex-1 flex-col p-5 sm:p-6', featured && 'md:w-1/2 md:justify-center']}>
    <div class="mb-3 flex flex-wrap items-center gap-2">
      {
        post.data.tags.slice(0, 3).map((tag) => (
          <span class="th-badge th-badge-blue">{tag}</span>
        ))
      }
    </div>

    <h2
      class:list={[
        'font-semibold tracking-tight text-slate-900 transition-colors group-hover:text-brand-blue-600 dark:text-white dark:group-hover:text-brand-blue-400',
        featured ? 'text-2xl sm:text-3xl' : 'text-lg',
      ]}
    >
      {post.data.title}
    </h2>

    <p
      class:list={[
        'mt-2 text-slate-600 dark:text-slate-300',
        featured ? 'text-base leading-relaxed line-clamp-3' : 'text-sm leading-relaxed line-clamp-2',
      ]}
    >
      {post.data.description}
    </p>

    <div class="mt-auto flex items-center gap-2 pt-5 text-sm text-slate-500 dark:text-slate-400">
      <span class="font-medium text-slate-700 dark:text-slate-200">{post.data.author}</span>
      <span aria-hidden="true">·</span>
      <time datetime={post.data.publishedDate.toISOString()}>{published}</time>
    </div>
  </div>
</a>
