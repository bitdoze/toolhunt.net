---
import { getCollection } from 'astro:content';
import SectionLayout from '../../layouts/SectionLayout.astro';
import { sortByDateDesc, uniqueSorted } from '../../lib/content';

const allTools = sortByDateDesc(await getCollection('sh'));
const categories = uniqueSorted(allTools.map((tool) => tool.data.category));
const alternativeTo = uniqueSorted(allTools.map((tool) => tool.data.alternativeTo));
---

<SectionLayout
  title="Open Source Self-hosted Apps for Your Business"
  description="Discover open-source alternatives to popular services that you can host yourself."
  tools={allTools}
  categories={categories}
  alternativeTo={alternativeTo}
  showAlternativeTo={true}
  itemsPerPage={50}
  section="sh"
/>
