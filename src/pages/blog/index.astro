---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
);

const [featured, ...rest] = posts;
---

<BaseLayout
  title="Blog - ToolHunt"
  description="Explore our latest articles about self-hosting, open-source tools, Mac apps, and technology guides."
>
  <div class="th-container py-10 sm:py-12">
    <header class="mb-10 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue-600 dark:text-brand-blue-400">
        Blog
      </p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        Guides, roundups, and product notes
      </h1>
      <p class="mt-3 text-base leading-relaxed text-slate-600 dark:text-slate-300">
        Practical writing on self-hosting, open-source tools, Mac software, and how to pick the right stack.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <div class="th-card p-10 text-center">
          <p class="text-slate-600 dark:text-slate-300">No posts yet. Check back soon.</p>
        </div>
      ) : (
        <div class="space-y-8">
          {featured && (
            <section aria-label="Featured post">
              <BlogCard post={featured} featured />
            </section>
          )}

          {rest.length > 0 && (
            <section aria-label="All posts">
              <div class="mb-5 flex items-center justify-between gap-4">
                <h2 class="th-section-title">All articles</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  {posts.length} {posts.length === 1 ? 'post' : 'posts'}
                </p>
              </div>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {rest.map((post) => (
                  <BlogCard post={post} />
                ))}
              </div>
            </section>
          )}
        </div>
      )
    }
  </div>
</BaseLayout>
