---
import { getCollection } from 'astro:content';
import SectionLayout from '../../layouts/SectionLayout.astro';
import { sortByDateDesc, uniqueSorted } from '../../lib/content';

const allTools = sortByDateDesc(await getCollection('tools'));
const categories = uniqueSorted(allTools.map((tool) => tool.data.category));
---

<SectionLayout
  title="Best Online Tools for You"
  description="Explore a curated collection of web-based tools and services that can help you and your business."
  tools={allTools}
  categories={categories}
  showAlternativeTo={false}
  itemsPerPage={12}
  section="tools"
/>
