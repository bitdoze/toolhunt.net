---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ToolGrid from '../components/ToolGrid.astro';
import SearchBar from '../components/SearchBar.astro';
import CategoryFilters from '../components/CategoryFilters.astro';
import { getCollection } from 'astro:content';
import {
  sortByDateDesc,
  toSearchIndexItem,
  uniqueSorted,
  type ToolEntry,
} from '../lib/content';

const [shEntries, toolEntries, alternativeEntries, macEntries, blogEntries] = await Promise.all([
  getCollection('sh'),
  getCollection('tools'),
  getCollection('alternatives'),
  getCollection('mac'),
  getCollection('blog'),
]);

const allTools: ToolEntry[] = [...shEntries, ...toolEntries, ...alternativeEntries, ...macEntries];
const searchIndex = allTools.map(toSearchIndexItem);

const shCategories = uniqueSorted(shEntries.map((entry) => entry.data.category));
const toolCategories = uniqueSorted(toolEntries.map((entry) => entry.data.category));
const macCategories = uniqueSorted(macEntries.map((entry) => entry.data.category));

const latestShEntries = sortByDateDesc(shEntries).slice(0, 6);
const latestToolEntries = sortByDateDesc(toolEntries).slice(0, 6);
const latestAlternativeEntries = sortByDateDesc(alternativeEntries).slice(0, 6);
const latestMacEntries = sortByDateDesc(macEntries).slice(0, 6);
const latestBlogEntries = sortByDateDesc(blogEntries).slice(0, 3);

const totalTools = allTools.length;

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'ToolHunt',
      url: 'https://toolhunt.net/',
      description:
        'Discover and compare self-hosted applications, online tools, and their alternatives.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://toolhunt.net/?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      name: 'ToolHunt',
      url: 'https://toolhunt.net/',
      logo: 'https://toolhunt.net/images/logo.svg',
    },
  ],
};
---

<BaseLayout
  title="ToolHunt - Find the Perfect Tools for Your Workflow"
  description="Discover and compare self-hosted applications, online tools, and their alternatives."
  image="/og-image.svg"
  jsonLd={homeJsonLd}
>
  <Hero
    totalTools={totalTools}
    shCount={shEntries.length}
    toolsCount={toolEntries.length}
    macCount={macEntries.length}
    alternativesCount={alternativeEntries.length}
  />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white sm:text-5xl md:text-6xl">
        <span class="block">Search Our</span>
        <span class="block text-brand-blue">Tools</span>
      </h1>

      <div class="mt-8 max-w-xl mx-auto">
        <SearchBar tools={searchIndex} mode="global" placeholder="Search across all tools..." />
      </div>
    </div>

    <div data-home-browse>
      <div class="mb-12">
        <CategoryFilters
          shCategories={shCategories}
          toolCategories={toolCategories}
          macCategories={macCategories}
          selectedCategories={[]}
        />
      </div>

      <section class="mb-16 p-6 bg-brand-blue/10 dark:bg-brand-blue/20 rounded-xl">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest Self-hosted Apps</h2>
          <a
            href="/sh/"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-brand-blue text-white hover:bg-brand-blue/90 transition-colors duration-200 font-medium"
          >
            View all <span class="ml-2">→</span>
          </a>
        </div>
        <ToolGrid tools={latestShEntries} />
      </section>

      <section class="mb-16 p-6 bg-brand-green/10 dark:bg-brand-green/20 rounded-xl">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest Online Tools</h2>
          <a
            href="/tools/"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-brand-green text-white hover:bg-brand-green/90 transition-colors duration-200 font-medium"
          >
            View all <span class="ml-2">→</span>
          </a>
        </div>
        <ToolGrid tools={latestToolEntries} />
      </section>

      <section class="mb-16 p-6 bg-brand-purple/10 dark:bg-brand-purple/20 rounded-xl">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest Alternatives</h2>
          <a
            href="/alternatives/"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-brand-purple text-white hover:bg-brand-purple/90 transition-colors duration-200 font-medium"
          >
            View all <span class="ml-2">→</span>
          </a>
        </div>
        <ToolGrid tools={latestAlternativeEntries} />
      </section>

      <section class="mb-16 p-6 bg-orange-50 dark:bg-orange-900/20 rounded-xl">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest Mac Apps</h2>
          <a
            href="/mac/"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-orange-600 text-white hover:bg-orange-700 transition-colors duration-200 font-medium"
          >
            View all <span class="ml-2">→</span>
          </a>
        </div>
        <ToolGrid tools={latestMacEntries} />
      </section>

      <section class="mb-16 p-6 bg-rose-50 dark:bg-rose-900/20 rounded-xl">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Latest from Blog</h2>
          <a
            href="/blog/"
            class="inline-flex items-center px-4 py-2 rounded-lg bg-rose-600 text-white hover:bg-rose-700 transition-colors duration-200 font-medium"
          >
            View all <span class="ml-2">→</span>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            latestBlogEntries.map((post) => (
              <article class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full aspect-video object-cover"
                    width="640"
                    height="360"
                    loading="lazy"
                  />
                )}
                <div class="p-6">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                    <a href={`/blog/${post.id}/`} class="hover:text-brand-blue">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="mt-3 text-gray-600 dark:text-gray-300 line-clamp-3">
                    {post.data.description}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="text-center py-12 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-800 rounded-2xl">
        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
          <span class="block">Ready to find your tools?</span>
        </h2>
        <p class="mt-4 text-lg leading-6 text-gray-500 dark:text-gray-400">
          Explore our complete collection of tools and alternatives.
        </p>
        <div class="mt-8 flex justify-center gap-4">
          <a
            href="/sh/"
            class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-brand-blue hover:bg-brand-blue/90"
          >
            Browse Self-hosted Apps
          </a>
          <a
            href="/tools/"
            class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-brand-blue bg-brand-blue/10 hover:bg-brand-blue/20 dark:text-brand-blue dark:bg-brand-blue/20 dark:hover:bg-brand-blue/30"
          >
            Explore Online Tools
          </a>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
