---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ToolGrid from '../components/ToolGrid.astro';
import CategoryFilters from '../components/CategoryFilters.astro';
import { getCollection } from 'astro:content';
import {
  sortByDateDesc,
  toSearchIndexItem,
  uniqueSorted,
  type ToolEntry,
} from '../lib/content';

const [shEntries, toolEntries, alternativeEntries, macEntries, blogEntries] = await Promise.all([
  getCollection('sh'),
  getCollection('tools'),
  getCollection('alternatives'),
  getCollection('mac'),
  getCollection('blog'),
]);

const allTools: ToolEntry[] = [...shEntries, ...toolEntries, ...alternativeEntries, ...macEntries];
const searchIndex = allTools.map(toSearchIndexItem);

const shCategories = uniqueSorted(shEntries.map((entry) => entry.data.category));
const toolCategories = uniqueSorted(toolEntries.map((entry) => entry.data.category));
const macCategories = uniqueSorted(macEntries.map((entry) => entry.data.category));

const latestShEntries = sortByDateDesc(shEntries).slice(0, 6);
const latestToolEntries = sortByDateDesc(toolEntries).slice(0, 6);
const latestAlternativeEntries = sortByDateDesc(alternativeEntries).slice(0, 6);
const latestMacEntries = sortByDateDesc(macEntries).slice(0, 6);
const latestBlogEntries = sortByDateDesc(blogEntries).slice(0, 3);

const totalTools = allTools.length;

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'ToolHunt',
      url: 'https://toolhunt.net/',
      description:
        'Discover and compare self-hosted applications, online tools, and their alternatives.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://toolhunt.net/?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      name: 'ToolHunt',
      url: 'https://toolhunt.net/',
      logo: 'https://toolhunt.net/images/logo.svg',
    },
  ],
};

const rails = [
  {
    title: 'Latest self-hosted apps',
    href: '/sh/',
    tools: latestShEntries,
    accent: 'bg-brand-blue-500',
  },
  {
    title: 'Latest online tools',
    href: '/tools/',
    tools: latestToolEntries,
    accent: 'bg-brand-green-500',
  },
  {
    title: 'Latest alternatives',
    href: '/alternatives/',
    tools: latestAlternativeEntries,
    accent: 'bg-brand-purple-500',
  },
  {
    title: 'Latest Mac apps',
    href: '/mac/',
    tools: latestMacEntries,
    accent: 'bg-brand-indigo-500',
  },
] as const;
---

<BaseLayout
  title="ToolHunt - Find the Perfect Tools for Your Workflow"
  description="Discover and compare self-hosted applications, online tools, and their alternatives."
  image="/og-image.svg"
  jsonLd={homeJsonLd}
>
  <Hero
    totalTools={totalTools}
    shCount={shEntries.length}
    toolsCount={toolEntries.length}
    macCount={macEntries.length}
    alternativesCount={alternativeEntries.length}
    searchIndex={searchIndex}
  />

  <div class="th-container py-12 sm:py-14" data-home-browse>
    <section class="mb-12">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <h2 class="th-section-title">Browse by category</h2>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
            Jump straight into a collection filter.
          </p>
        </div>
      </div>
      <CategoryFilters
        shCategories={shCategories}
        toolCategories={toolCategories}
        macCategories={macCategories}
        selectedCategories={[]}
      />
    </section>

    {
      rails.map((rail) => (
        <section class="relative mb-14 pl-4 sm:pl-5">
          <span class:list={['absolute left-0 top-1 h-8 w-1 rounded-full', rail.accent]}></span>
          <div class="mb-5 flex items-center justify-between gap-4">
            <h2 class="th-section-title">{rail.title}</h2>
            <a href={rail.href} class="th-btn th-btn-secondary">
              View all
              <span aria-hidden="true">→</span>
            </a>
          </div>
          <ToolGrid tools={rail.tools} />
        </section>
      ))
    }

    <section class="relative mb-14 pl-4 sm:pl-5">
      <span class="absolute left-0 top-1 h-8 w-1 rounded-full bg-rose-500"></span>
      <div class="mb-5 flex items-center justify-between gap-4">
        <h2 class="th-section-title">Latest from the blog</h2>
        <a href="/blog/" class="th-btn th-btn-secondary">
          View all
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          latestBlogEntries.map((post) => (
            <article class="th-card th-card-hover overflow-hidden">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="aspect-video w-full object-cover"
                  width="640"
                  height="360"
                  loading="lazy"
                />
              )}
              <div class="p-5">
                <h3 class="text-lg font-semibold tracking-tight text-slate-900 dark:text-white">
                  <a href={`/blog/${post.id}/`} class="hover:text-brand-blue-600 dark:hover:text-brand-blue-400">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                  {post.data.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="th-card px-6 py-10 text-center sm:px-10">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl dark:text-white">
        Ready to explore the full catalog?
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-600 dark:text-slate-300">
        Start with self-hosted apps or browse online tools and Mac software.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/sh/" class="th-btn th-btn-primary px-5 py-2.5">Browse self-hosted apps</a>
        <a href="/tools/" class="th-btn th-btn-secondary px-5 py-2.5">Explore online tools</a>
        <a href="/submit/" class="th-btn th-btn-ghost px-5 py-2.5">Submit a tool</a>
      </div>
    </section>
  </div>
</BaseLayout>
