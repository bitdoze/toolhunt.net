---
import { getCollection } from 'astro:content';
import SectionLayout from '../../layouts/SectionLayout.astro';
import { sortByDateDesc, uniqueSorted } from '../../lib/content';

const allTools = sortByDateDesc(await getCollection('mac'));
const categories = uniqueSorted(allTools.map((tool) => tool.data.category));
const pricingOptions = ['Free', 'Paid', 'Freemium'];
---

<SectionLayout
  title="Collection with FREE Mac Apps and Tools"
  description="Discover the best Mac applications for productivity, development, and creativity that will help you with your work"
  tools={allTools}
  categories={categories}
  pricingOptions={pricingOptions}
  showPricing={true}
  itemsPerPage={50}
  section="mac"
/>
