---
import { getCollection } from 'astro:content';
import SectionLayout from '../../layouts/SectionLayout.astro';
import {
  alternativeToUrl,
  getAlternativeGroups,
  sortByDateDesc,
  uniqueSorted,
} from '../../lib/content';

const allTools = sortByDateDesc(await getCollection('alternatives'));
const categories = uniqueSorted(allTools.map((tool) => tool.data.category));
const alternativeTo = uniqueSorted(allTools.map((tool) => tool.data.alternativeTo));
const popularAlternatives = (await getAlternativeGroups())
  .filter((group) => group.tools.length > 1)
  .slice(0, 12)
  .map((group) => ({
    name: group.name,
    href: alternativeToUrl(group.name),
    count: group.tools.length,
  }));
---

<SectionLayout
  title="Alternatives"
  description="Find open-source and free alternatives to popular proprietary software."
  tools={allTools}
  categories={categories}
  alternativeTo={alternativeTo}
  showAlternativeTo={true}
  itemsPerPage={12}
  section="alternatives"
  popularAlternatives={popularAlternatives}
/>
