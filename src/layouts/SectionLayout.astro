---
import BaseLayout from './BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import Filters from '../components/Filters.astro';
import ToolCard from '../components/ToolCard.astro';
import {
  getAlternativeTo,
  getCheckItUrl,
  getPricing,
  toolUrl,
  type ToolCollection,
  type ToolEntry,
} from '../lib/content';

export type CatalogSection = ToolCollection | 'ai';

interface Props {
  title: string;
  description: string;
  tools: ToolEntry[];
  categories: string[];
  alternativeTo?: string[];
  showAlternativeTo?: boolean;
  pricingOptions?: string[];
  showPricing?: boolean;
  itemsPerPage?: number;
  section: CatalogSection;
  popularAlternatives?: Array<{ name: string; href: string; count: number }>;
}

const {
  title,
  description,
  tools,
  categories,
  alternativeTo = [],
  showAlternativeTo = false,
  pricingOptions = [],
  showPricing = false,
  itemsPerPage = 50,
  section,
  popularAlternatives = [],
} = Astro.props;

const categoryCounts = Object.fromEntries(
  categories.map((category) => [
    category,
    tools.filter((tool) => tool.data.category === category).length,
  ])
);

const alternativeCounts = Object.fromEntries(
  alternativeTo.map((alt) => [
    alt,
    tools.filter((tool) => getAlternativeTo(tool) === alt).length,
  ])
);

const pricingCounts = Object.fromEntries(
  pricingOptions.map((price) => [
    price,
    tools.filter((tool) => getPricing(tool) === price).length,
  ])
);

const sectionOgImages: Record<CatalogSection, string> = {
  sh: '/images/logo.svg',
  tools: '/images/logo.svg',
  mac: '/images/logo.svg',
  alternatives: '/images/logo.svg',
  ai: '/images/logo.svg',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: new URL(`/${section}/`, Astro.site).toString(),
  numberOfItems: tools.length,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: tools.length,
    itemListElement: tools.slice(0, 50).map((tool, index) => {
      const checkItUrl = getCheckItUrl(tool);
      return {
        '@type': 'ListItem',
        position: index + 1,
        url: new URL(toolUrl(tool), Astro.site).toString(),
        item: {
          '@type': 'SoftwareApplication',
          name: tool.data.title,
          description: tool.data.description,
          image: new URL(tool.data.logo, Astro.site).toString(),
          applicationCategory: tool.data.category,
          url: new URL(toolUrl(tool), Astro.site).toString(),
          ...(checkItUrl ? { sameAs: [checkItUrl] } : {}),
        },
      };
    }),
  },
};

const metaDescription = `${description} Browse ${tools.length} tools across ${categories.length} categories${
  showAlternativeTo ? ` and find alternatives to popular services` : ''
}.`;
---

<BaseLayout
  title={title}
  description={metaDescription}
  jsonLd={jsonLd}
  image={sectionOgImages[section]}
  section={title}
>
  <div class="th-container py-8 sm:py-10" data-catalog-root>
    <div class="flex flex-col gap-8 lg:flex-row lg:gap-10">
      <aside class="w-full shrink-0 lg:w-72">
        <div class="sticky top-24 space-y-4">
          <SearchBar mode="local" placeholder={`Search ${title.toLowerCase()}...`} />
          <Filters
            categories={categories}
            alternativeTo={alternativeTo}
            pricingOptions={pricingOptions}
            showAlternativeTo={showAlternativeTo}
            showPricing={showPricing}
            categoryCounts={categoryCounts}
            alternativeCounts={alternativeCounts}
            pricingCounts={pricingCounts}
          />
        </div>
      </aside>

      <div class="min-w-0 flex-1">
        <header class="mb-6 border-b border-slate-200 pb-5 dark:border-slate-800">
          <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">
            {title}
          </h1>
          <p class="mt-2 max-w-3xl text-slate-600 dark:text-slate-300">{description}</p>
          <p
            id="results-count"
            class="mt-3 text-sm text-slate-500 dark:text-slate-400"
            data-results-count
            aria-live="polite"
            aria-atomic="true"
          >
            Showing {tools.length} tools
          </p>
        </header>

        {
          popularAlternatives.length > 0 && (
            <section class="th-card mb-8 p-5">
              <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                Popular alternatives-to pages
              </h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {popularAlternatives.map((item) => (
                  <a
                    href={item.href}
                    class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 transition-colors hover:bg-brand-purple-50 hover:text-brand-purple-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple-500 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-brand-purple-900/40 dark:hover:text-brand-purple-100"
                  >
                    {item.name}
                    <span class="ml-1.5 text-slate-400 dark:text-slate-500">{item.count}</span>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        <div
          id="tools-grid"
          class="mb-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
          data-tools-grid
        >
          {
            tools.map((tool, index) => {
              const pricing = getPricing(tool) || '';
              const alt = getAlternativeTo(tool) || '';
              const features = tool.data.keyFeatures?.join(' ') || '';
              const searchText = [
                tool.data.title,
                tool.data.description,
                tool.data.category,
                alt,
                pricing,
                features,
                tool.id,
              ]
                .filter(Boolean)
                .join(' ')
                .toLowerCase();

              return (
                <div
                  class="tool-item h-full"
                  data-tool-item
                  data-search={searchText}
                  data-category={tool.data.category}
                  data-alternative-to={alt}
                  data-pricing={pricing}
                >
                  <ToolCard entry={tool} priority={index < 3} />
                </div>
              );
            })
          }
        </div>

        <div
          id="catalog-empty"
          class="th-card hidden border-dashed px-6 py-16 text-center"
          data-catalog-empty
        >
          <p class="text-lg font-semibold text-slate-900 dark:text-white">No matching tools</p>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            Try clearing filters or using a shorter search term.
          </p>
          <button type="button" data-reset-catalog class="th-btn th-btn-primary mt-5">
            Reset filters
          </button>
        </div>

        <nav
          id="pagination"
          class="mb-4 hidden justify-center flex-wrap gap-2 text-center"
          aria-label="Pagination"
          data-pagination
        ></nav>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ itemsPerPage, section, totalTools: tools.length }}>
  function getState() {
    const params = new URLSearchParams(window.location.search);
    const searchInput = document.querySelector('[data-search-input]');
    const filterForm = document.querySelector('[data-catalog-filters]');

    const categories = filterForm
      ? Array.from(filterForm.querySelectorAll('input[name="category"]:checked')).map((el) => el.value)
      : params.getAll('category');
    const alternatives = filterForm
      ? Array.from(filterForm.querySelectorAll('input[name="alternativeTo"]:checked')).map(
          (el) => el.value
        )
      : params.getAll('alternativeTo');
    const pricing = filterForm
      ? Array.from(filterForm.querySelectorAll('input[name="pricing"]:checked')).map((el) => el.value)
      : params.getAll('pricing');

    const q = (searchInput?.value || params.get('q') || '').toLowerCase().trim();
    const page = Math.max(1, parseInt(params.get('page') || '1', 10) || 1);

    return { q, categories, alternatives, pricing, page };
  }

  function matches(item, state) {
    if (state.q) {
      const haystack = item.dataset.search || '';
      if (!haystack.includes(state.q)) return false;
    }
    if (state.categories.length > 0 && !state.categories.includes(item.dataset.category || '')) {
      return false;
    }
    if (
      state.alternatives.length > 0 &&
      !state.alternatives.includes(item.dataset.alternativeTo || '')
    ) {
      return false;
    }
    if (state.pricing.length > 0 && !state.pricing.includes(item.dataset.pricing || '')) {
      return false;
    }
    return true;
  }

  function writeUrl(state) {
    const params = new URLSearchParams();
    if (state.q) params.set('q', state.q);
    for (const value of state.categories) params.append('category', value);
    for (const value of state.alternatives) params.append('alternativeTo', value);
    for (const value of state.pricing) params.append('pricing', value);
    if (state.page > 1) params.set('page', String(state.page));

    const query = params.toString();
    const next = query ? `${window.location.pathname}?${query}` : window.location.pathname;
    window.history.replaceState({}, '', next);
  }

  function pageHref(page) {
    const state = getState();
    state.page = page;
    const params = new URLSearchParams();
    if (state.q) params.set('q', state.q);
    for (const value of state.categories) params.append('category', value);
    for (const value of state.alternatives) params.append('alternativeTo', value);
    for (const value of state.pricing) params.append('pricing', value);
    if (page > 1) params.set('page', String(page));
    const query = params.toString();
    return query ? `${window.location.pathname}?${query}` : window.location.pathname;
  }

  function renderPagination(currentPage, totalPages) {
    const nav = document.querySelector('[data-pagination]');
    if (!nav) return;

    if (totalPages <= 1) {
      nav.classList.add('hidden');
      nav.classList.remove('flex');
      nav.replaceChildren();
      return;
    }

    nav.classList.remove('hidden');
    nav.classList.add('flex');

    const btn =
      'border border-brand-blue-500/40 hover:bg-brand-blue-600 hover:text-white rounded-md min-w-10 h-10 px-2 leading-[36px] font-semibold text-gray-700 dark:text-gray-200 flex items-center justify-center transition duration-200';
    const active =
      'border border-brand-blue-600 bg-brand-blue-600 rounded-md min-w-10 h-10 px-2 leading-[36px] font-semibold text-white flex items-center justify-center';

    const parts = [];
    if (currentPage > 1) {
      parts.push(
        `<a href="${pageHref(currentPage - 1)}" data-page="${currentPage - 1}" class="${btn}" aria-label="Previous">‹</a>`
      );
    }

    const windowSize = 7;
    let start = Math.max(1, currentPage - Math.floor(windowSize / 2));
    let end = Math.min(totalPages, start + windowSize - 1);
    start = Math.max(1, end - windowSize + 1);

    if (start > 1) {
      parts.push(`<a href="${pageHref(1)}" data-page="1" class="${btn}">1</a>`);
      if (start > 2) parts.push(`<span class="px-1 text-gray-400">…</span>`);
    }

    for (let page = start; page <= end; page++) {
      if (page === currentPage) {
        parts.push(`<span aria-current="page" class="${active}">${page}</span>`);
      } else {
        parts.push(`<a href="${pageHref(page)}" data-page="${page}" class="${btn}">${page}</a>`);
      }
    }

    if (end < totalPages) {
      if (end < totalPages - 1) parts.push(`<span class="px-1 text-gray-400">…</span>`);
      parts.push(
        `<a href="${pageHref(totalPages)}" data-page="${totalPages}" class="${btn}">${totalPages}</a>`
      );
    }

    if (currentPage < totalPages) {
      parts.push(
        `<a href="${pageHref(currentPage + 1)}" data-page="${currentPage + 1}" class="${btn}" aria-label="Next">›</a>`
      );
    }

    nav.innerHTML = parts.join('');
  }

  function applyCatalog(options = {}) {
    const root = document.querySelector('[data-catalog-root]');
    if (!root) return;

    const grid = root.querySelector('[data-tools-grid]');
    const countEl = root.querySelector('[data-results-count]');
    const emptyEl = root.querySelector('[data-catalog-empty]');
    if (!grid) return;

    const items = Array.from(grid.querySelectorAll('[data-tool-item]'));
    const state = getState();
    if (options.resetPage) state.page = 1;

    const matched = items.filter((item) => matches(item, state));
    const totalPages = Math.max(1, Math.ceil(matched.length / itemsPerPage) || 1);
    state.page = Math.min(Math.max(1, state.page), totalPages);

    const start = (state.page - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const visible = new Set(matched.slice(start, end));

    for (const item of items) {
      item.classList.toggle('hidden', !visible.has(item));
    }

    if (countEl) {
      if (matched.length === 0) {
        countEl.textContent = 'No tools match your filters';
      } else if (matched.length === totalTools && !state.q && state.categories.length === 0 && state.alternatives.length === 0 && state.pricing.length === 0) {
        countEl.textContent = `Showing ${matched.length} ${section} tools`;
      } else {
        const shown = Math.min(itemsPerPage, matched.length - start);
        countEl.textContent = `Showing ${shown} of ${matched.length} matching tools`;
      }
    }

    if (emptyEl) {
      emptyEl.classList.toggle('hidden', matched.length > 0);
      grid.classList.toggle('hidden', matched.length === 0);
    }

    renderPagination(state.page, totalPages);
    writeUrl(state);
  }

  function onCatalogUpdate(event) {
    applyCatalog({ resetPage: Boolean(event?.detail?.resetPage) });
  }

  function onPaginationClick(event) {
    const link = event.target.closest('[data-pagination] a[data-page]');
    if (!link) return;
    event.preventDefault();
    const page = parseInt(link.dataset.page || '1', 10) || 1;
    const params = new URLSearchParams(window.location.search);
    if (page <= 1) params.delete('page');
    else params.set('page', String(page));
    const query = params.toString();
    window.history.replaceState(
      {},
      '',
      query ? `${window.location.pathname}?${query}` : window.location.pathname
    );
    applyCatalog({ resetPage: false });
    document.querySelector('[data-tools-grid]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function resetAll() {
    const form = document.querySelector('[data-catalog-filters]');
    const searchInput = document.querySelector('[data-search-input]');
    form?.querySelectorAll('input[type="checkbox"]').forEach((checkbox) => {
      checkbox.checked = false;
    });
    if (searchInput) {
      searchInput.value = '';
      searchInput.dispatchEvent(new Event('input', { bubbles: true }));
    }
    document.querySelector('[data-search-clear]')?.classList.add('hidden');
    document.querySelector('[data-active-filters]')?.classList.add('hidden');
    document.querySelector('[data-active-filters]')?.replaceChildren();
    applyCatalog({ resetPage: true });
  }

  function onResetClick(event) {
    const target = event.target;
    if (!(target instanceof Element)) return;
    // Empty-state "Reset filters" and sidebar "Clear all" share the same full reset.
    if (target.closest('[data-reset-catalog], [data-clear-filters]')) {
      event.preventDefault();
      resetAll();
    }
  }

  function bootCatalog() {
    if (!document.querySelector('[data-catalog-root]')) return;
    applyCatalog({ resetPage: false });
  }

  if (!window.__toolhuntCatalogBound) {
    window.__toolhuntCatalogBound = true;
    document.addEventListener('toolhunt:catalog-update', onCatalogUpdate);
    document.addEventListener('click', onPaginationClick);
    document.addEventListener('click', onResetClick);
  }

  bootCatalog();
  document.addEventListener('astro:page-load', bootCatalog);
</script>
