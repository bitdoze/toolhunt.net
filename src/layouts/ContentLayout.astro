---
import BaseLayout from './BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import ToolImage from '../components/ToolImage.astro';
import {
  alternativeToUrl,
  buildSoftwareApplicationJsonLd,
  collectionLabel,
  getAllTools,
  getAlternativeTo,
  getCheckItUrl,
  getCollectionTools,
  getPricing,
  getRelatedTools,
  ogImageUrl,
  type ToolEntry,
} from '../lib/content';

interface Props {
  entry: ToolEntry;
}

const { entry } = Astro.props;
const { title, description, uiImage, logo, category } = entry.data;
const checkItUrl = getCheckItUrl(entry);
const alternativeTo = getAlternativeTo(entry);
const pricing = getPricing(entry);
const [pool, allTools] = await Promise.all([
  getCollectionTools(entry.collection),
  getAllTools(),
]);
const relatedTools = getRelatedTools(entry, pool, 6, allTools);
const sameAlternativeTools = alternativeTo
  ? relatedTools.filter((tool) => getAlternativeTo(tool) === alternativeTo)
  : [];
const categoryRelated = relatedTools.filter(
  (tool) =>
    !sameAlternativeTools.some(
      (alt) => alt.id === tool.id && alt.collection === tool.collection
    )
);
const socialImage = ogImageUrl(entry);
const jsonLd = buildSoftwareApplicationJsonLd(entry);
const sectionLabel = collectionLabel(entry.collection);
const sectionHref = `/${entry.collection}/`;
---

<BaseLayout
  title={title}
  description={description}
  image={socialImage}
  type="article"
  jsonLd={jsonLd}
  publishedTime={entry.data.publishedDate.toISOString()}
  section={sectionLabel}
>
  <div class="th-container py-8 sm:py-10">
    <nav class="mb-6 text-sm text-slate-500 dark:text-slate-400" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2 font-medium">
        <li><a href="/" class="hover:text-brand-blue-600 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-slate-300 dark:text-slate-700">/</li>
        <li>
          <a href={sectionHref} class="hover:text-brand-blue-600 transition-colors">{sectionLabel}</a>
        </li>
        <li aria-hidden="true" class="text-slate-300 dark:text-slate-700">/</li>
        <li class="font-semibold text-slate-900 dark:text-white">{title}</li>
      </ol>
    </nav>

    <header class="th-card mb-8 p-6 sm:p-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        <div class="rounded-2xl border border-slate-200/90 bg-slate-50/80 p-3.5 dark:border-slate-700/80 dark:bg-slate-800/80 shrink-0">
          <ToolImage
            src={logo}
            alt={`${title} logo`}
            width={72}
            height={72}
            class="h-16 w-16 object-contain sm:h-[72px] sm:w-[72px]"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="min-w-0 flex-1">
          <div class="mb-3 flex flex-wrap gap-2">
            <span class="th-badge th-badge-neutral font-medium">{sectionLabel}</span>
            <span class="th-badge th-badge-blue font-medium">{category}</span>
            {pricing && <span class="th-badge th-badge-green font-semibold">{pricing}</span>}
            {alternativeTo && (
              <a href={alternativeToUrl(alternativeTo)} class="th-badge th-badge-purple hover:opacity-90 transition-opacity">
                Alt to {alternativeTo}
              </a>
            )}
          </div>
          <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white" style="text-wrap: balance;">
            {title}
          </h1>
          <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg dark:text-slate-300">
            {description}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            {checkItUrl && (
              <a
                href={checkItUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="th-btn th-btn-primary px-5 py-2.5 shadow-xs"
              >
                Visit official site
                <svg class="ml-1.5 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
            {alternativeTo && (
              <a href={alternativeToUrl(alternativeTo)} class="th-btn th-btn-secondary px-5 py-2.5">
                More alternatives to {alternativeTo}
              </a>
            )}
          </div>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-4xl">
      <section class="mb-10">
        <h2 class="th-section-title mb-4">Interface preview</h2>
        <div class="th-card overflow-hidden">
          <div class="flex items-center gap-1.5 border-b border-slate-200/80 bg-slate-100/70 px-4 py-2.5 dark:border-slate-800 dark:bg-slate-800/50">
            <span class="h-2.5 w-2.5 rounded-full bg-slate-300 dark:bg-slate-700"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-slate-300 dark:bg-slate-700"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-slate-300 dark:bg-slate-700"></span>
            <span class="ml-2 text-xs font-mono text-slate-400 dark:text-slate-500 truncate max-w-xs">{title.toLowerCase().replace(/[^a-z0-9]/g, '')}.app</span>
          </div>
          <div class="p-2 sm:p-3 bg-slate-50 dark:bg-slate-900/40">
            <ToolImage
              src={uiImage}
              alt={`${title} user interface`}
              class="w-full rounded-lg shadow-xs"
              width={1200}
              height={675}
              loading="lazy"
            />
          </div>
        </div>
      </section>

      {
        entry.data.youtubeId && (
          <section class="mb-10">
            <h2 class="th-section-title mb-4">Video overview</h2>
            <div class="th-card relative h-0 overflow-hidden pb-[56.25%]">
              <iframe
                src={`https://www.youtube.com/embed/${entry.data.youtubeId}`}
                title={`${title} video overview`}
                class="absolute inset-0 h-full w-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              />
            </div>
          </section>
        )
      }

      <article class="prose prose-slate max-w-none dark:prose-invert prose-headings:tracking-tight prose-a:text-brand-blue-600 blog-prose">
        <slot />
      </article>

      <div class="mt-8">
        <ToolCard entry={entry} showFullDetails={true} />
      </div>
    </div>
  </div>

  {
    sameAlternativeTools.length > 0 && alternativeTo && (
      <div class="th-container">
        <section class="mt-12 border-t border-slate-200/80 pt-8 dark:border-slate-800">
          <div class="mb-5 flex items-end justify-between gap-4">
            <h2 class="th-section-title">More alternatives to {alternativeTo}</h2>
            <a href={alternativeToUrl(alternativeTo)} class="th-btn th-btn-secondary">
              View all
            </a>
          </div>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {sameAlternativeTools.slice(0, 3).map((tool) => (
              <ToolCard entry={tool} />
            ))}
          </div>
        </section>
      </div>
    )
  }

  {
    categoryRelated.length > 0 && (
      <div class="th-container">
        <section class="mt-12 border-t border-slate-200/80 pt-8 pb-12 dark:border-slate-800">
          <h2 class="th-section-title mb-5">
            More {entry.collection === 'mac' ? 'Mac ' : ''}
            {category} tools
          </h2>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {categoryRelated.slice(0, 3).map((tool) => (
              <ToolCard entry={tool} />
            ))}
          </div>
        </section>
      </div>
    )
  }
</BaseLayout>

