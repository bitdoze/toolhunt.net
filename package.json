{
    "name": "toolhunt.net",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev --host",
        "build": "astro build",
        "preview": "astro preview",
        "check": "astro check",
        "content:check": "node scripts/content-check.mjs",
        "content:check:remote": "CONTENT_CHECK_REMOTE=1 node scripts/content-check.mjs",
        "images:optimize": "node scripts/optimize-images.mjs",
        "new:entry": "node scripts/new-entry.mjs",
        "new:sh": "node scripts/new-entry.mjs sh",
        "new:mac": "node scripts/new-entry.mjs mac",
        "new:tools": "node scripts/new-entry.mjs tools",
        "lint": "astro check",
        "ci": "npm run content:check && npm run check && npm run build",
        "astro": "astro"
    },
    "engines": {
        "node": ">=22.12.0"
    },
    "dependencies": {
        "@astrojs/cloudflare": "^14.1.3",
        "@astrojs/mdx": "^7.0.3",
        "@astrojs/sitemap": "^3.7.3",
        "@iconify-json/mdi": "^1.2.3",
        "astro": "^7.0.9",
        "astro-icon": "^1.1.5",
        "fuse.js": "^7.5.0",
        "tailwindcss": "^4.3.2"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.2",
        "sharp": "^0.34.2",
        "typescript": "^6.0.3",
        "vite": "^8.1.4"
    }
}
